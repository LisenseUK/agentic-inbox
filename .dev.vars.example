# Cloudflare Access (required in production). TEAM_DOMAIN may be the base Access URL or the full /cdn-cgi/access/certs URL.
POLICY_AUD=your-access-policy-audience-tag
TEAM_DOMAIN=https://your-team.cloudflareaccess.com

# Optional: post a Discord notification for every received email.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Optional: catch-all mailbox — receives mail for any address with no dedicated mailbox.
# CATCH_ALL_MAILBOX=catchall@lisense.uk
